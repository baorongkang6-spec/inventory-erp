# 环境变量示例。生产复制为 .env 并改值（.env 不入库，见 .gitignore）。
# 开发期可全部留空，使用安全的开发默认值。

# --- 基本 ---
# 生产必开：启用全部安全加固（HTTPS/安全 Cookie/HSTS、fail-fast 校验）
DJANGO_PRODUCTION=1
# 生产必须 0（关调试）
DJANGO_DEBUG=0
# 生产必须设置（随机长字符串，勿入库）。开发留空用内置开发默认值。
DJANGO_SECRET_KEY=

# --- 域名 / CSRF（花生壳）---
# 逗号分隔，含花生壳域名与内网 IP
DJANGO_ALLOWED_HOSTS=your-name.iask.in,127.0.0.1,localhost
# 逗号分隔，必须带协议（生产必填）
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-name.iask.in

# --- 数据库（生产 PostgreSQL）---
DB_ENGINE=postgres
DB_NAME=inventory_erp
DB_USER=postgres
DB_PASSWORD=改成强密码
DB_HOST=127.0.0.1
DB_PORT=5432

# --- 安全细项（可选，PRODUCTION 下默认已安全）---
# DJANGO_SECURE_SSL_REDIRECT=1
# DJANGO_HSTS_SECONDS=2592000
# DJANGO_SESSION_EXPIRE_ON_CLOSE=0

# --- 登录防爆破 ---
LOGIN_FAILURE_LIMIT=5
LOGIN_LOCKOUT_SECONDS=900

# --- 业务 ---
# 启用日（期初基准日）
ERP_OPENING_DATE=2026-06-01
